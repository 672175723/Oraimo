rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: settings
    // Document: global
    // Fields: primaryColor, phone, whatsapp, email, siteName, seoTitle, seoDescription
    //
    // Collection: products
    // Fields: name, price, originalPrice, image, category, description, stock, isFlashSale, discount, soldCount
    //
    // Collection: orders
    // Fields: customerName, customerPhone, deliveryAddress, city, items, totalAmount, status, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidProduct(data) {
      return data.name is string && data.price is number;
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerPhone is string && data.items is list;
    }

    // Rules
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if true; // Permettre aux clients de passer des commandes
      allow update, delete: if isAdmin();
    }

    match /stats/{date} {
      allow read: if isAdmin();
      allow write: if true; // Allow tracking visits and cart activity
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId && request.resource.data.role == resource.data.role);
    }

    // Autoriser l'accès aux autres collections potentielles pour le public
    match /{path=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
